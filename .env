VITE_BACKEND_API=https://api.propertyspotter.co.za/
VITE_CURRENCY="R"
PUBLIC_SPOTTER_AGENCY=f6ddbed1-a2da-424e-84e6-20f1cd9014ae
VITE_TURNSTILE_SITE_KEY=0x4AAAAAABh0NmB0huVYpxH1

# Staff portal — replaces signing into the Django admin.
# VITE_LOGIN_ALIAS is the path the staff sign-in page is served from. Change it
# to something unguessable, rebuild and redeploy, and the old path stops
# resolving. Must keep the VITE_ prefix: Vite only exposes VITE_* to the browser.
VITE_LOGIN_ALIAS="/DeadlyMangoZebra"

# Dashboard behind the login. Optional; defaults to /admin.
VITE_STAFF_PORTAL_PATH=/admin
